# =============================================================================
# ddr_test_fixed_for_mes50h_stage4.fdc
# =============================================================================
# 该文件由原 ddr_test.fdc 修正而来，用于 MES50H 阶段4工程。
#
# 修正内容：
# 1. 注释原 DDR demo 的 create_clock ref_clk，因为当前顶层没有 ref_clk 端口。
# 2. 注释原 DDR demo 的 create_clock free_clk，因为 free_clk 已在 source/top.fdc 里定义。
# 3. generated clock 中的 ref_clk 改成 free_clk。
# 4. 注释 DDR demo 顶层独有端口约束：
#    ref_clk / rst_board / pll_lock / ddr_init_done /
#    heart_beat_led / err_flag_led / uart_txd / uart_rxd
# 5. 保留 DDR3 mem_* 物理引脚约束和 DDR3 PHY/DLL/PLL 约束。
#
# 使用方式：
# - 用本文件替换工程里你加入的 source/pnr/ddr_test.fdc；
#   或在 Pango 约束列表中删除旧 ddr_test.fdc，再加入本文件。
# - 保留原 source/top.fdc。
# =============================================================================

###==== BEGIN Clocks
# [MES50H_FIX] 当前顶层无 ref_clk，DDR3 ref_clk 已接 free_clk，注释原约束： create_clock -name {ref_clk} [get_ports {ref_clk}] -period {20.0} -waveform {0 10.0}
# [MES50H_FIX] free_clk 已在 source/top.fdc 中声明，避免重复声明： create_clock -name {free_clk} [get_ports {free_clk}] -period {20.000} -waveform {0.000 10.000}
###==== END Clocks

###==== BEGIN "Generated Clocks"
create_generated_clock -name {ddrphy_clkin} -source [get_ports {free_clk}] [get_pins {u_mesethernet_test.I_ipsxb_ddr_top.I_GTP_CLKDIV/CLKDIVOUT}] -master_clock [get_clocks {free_clk}] -multiply_by {16} -divide_by {8}
create_generated_clock -name {ioclk0} -source [get_ports {free_clk}] [get_pins {u_mesethernet_test.I_ipsxb_ddr_top.I_GTP_IOCLKBUF_0/CLKOUT}] -master_clock [get_clocks {free_clk}] -multiply_by {16} -divide_by {2}
create_generated_clock -name {ioclk1} -source [get_ports {free_clk}] [get_pins {u_mesethernet_test.I_ipsxb_ddr_top.I_GTP_IOCLKBUF_1/CLKOUT}] -master_clock [get_clocks {free_clk}] -multiply_by {16} -divide_by {2}
create_generated_clock -name {ioclk2} -source [get_ports {free_clk}] [get_pins {u_mesethernet_test.I_ipsxb_ddr_top.I_GTP_IOCLKBUF_2/CLKOUT}] -master_clock [get_clocks {free_clk}] -multiply_by {16} -divide_by {2}
create_generated_clock -name {ioclk_gate_clk} -source [get_ports {free_clk}] [get_pins {u_mesethernet_test.I_ipsxb_ddr_top.u_clkbufg_gate/CLKOUT}] -master_clock [get_clocks {free_clk}] -multiply_by {16} -divide_by {8}
###==== END "Generated Clocks"

###==== BEGIN "Inputs/Outpusts"
###==== END "Inputs/Outpusts"

###==== BEGIN "Delay Paths"
###==== END "Delay Paths"

###==== BEGIN set_clock_group"
set_clock_groups -name ref_clk -asynchronous -group [get_clocks {free_clk}]
set_clock_groups -name free_clk -asynchronous -group [get_clocks {free_clk}]
set_clock_groups -name ioclk0 -asynchronous -group [get_clocks {ioclk0}]
set_clock_groups -name ioclk1 -asynchronous -group [get_clocks {ioclk1}]
set_clock_groups -name ioclk2 -asynchronous -group [get_clocks {ioclk2}]
set_clock_groups -name ioclk_gate_clk -asynchronous -group [get_clocks {ioclk_gate_clk}]
###==== END "set_clock_group"

###==== BEGIN set_clock_uncertainty"
set_clock_uncertainty {0.200} [get_clocks {ddrphy_clkin}]  -setup -hold
###==== END "set_clock_group"

###==== BEGIN Attributes
define_attribute {i:u_mesethernet_test.I_ipsxb_ddr_top.u_ipsxb_ddrphy_pll_0.u_pll_e3} {PAP_LOC} {PLL_158_199}
define_attribute {i:u_mesethernet_test.I_ipsxb_ddr_top.u_ipsxb_ddrphy_pll_1.u_pll_e3} {PAP_LOC} {PLL_158_179}
define_attribute {i:u_mesethernet_test.I_ipsxb_ddr_top.u_ddrphy_top.ddrphy_reset_ctrl.ddrphy_ioclk_gate} {PAP_LOC} {CLMA_150_192:FF3}
###==== END Attributes

