# =============================================================================
# ATK_DFPGL22G OV5640 + DDR3 + LCD + RGMII UDP 总约束文件
# 目标器件：PGL22G-6MBG324
# 软件环境：Pango Design Suite 2022.2-SP6.4
#
# 生成来源：
#   1. ov5640_lcd.fdc       ：保留 OV5640 + DDR3 + LCD 主链路约束
#   2. ov5640_udp_pc.fdc    ：提取 RGMII/PHY 以太网端口约束
#   3. ATK-DFPGL22G_FPGA_IO.fdc：用于交叉核对管脚
#
# 顶层端口命名要求：
#   sys_clk, sys_rst_n
#   cam_pclk, cam_vsync, cam_href, cam_data[7:0], cam_rst_n, cam_pwdn, cam_scl, cam_sda
#   lcd_rgb[23:0], lcd_de, lcd_hs, lcd_vs, lcd_pclk, lcd_bl, lcd_rst
#   DDR3 端口保持 34_ov5640_lcd 原工程命名
#   eth_rxc, eth_rx_ctl, eth_rxd[3:0], eth_txc, eth_tx_ctl, eth_txd[3:0], eth_rst_n
#
# 说明：
#   - 本文件直接以 34_ov5640_lcd 原约束为主体，不修改 DDR3/LCD/OV5640 已验证约束。
#   - 以太网约束来自 48_ov5640_udp_pc，使用 12mA + FAST，适合 RGMII 边沿速率需求。
#   - 已补充 eth_rxc 输入时钟约束：周期 8ns，即 125MHz。
#   - 若你的最终顶层端口名不同，请只改端口名，不要随意改 LOC。
# =============================================================================

create_clock -name {sys_clk} [get_ports {sys_clk}] -period {20} -waveform {0.000 10.000}
create_clock -name {cam_pclk} [get_ports {cam_pclk}] -period {20.000} -waveform {0.000 10.000}
create_clock -name {eth_rxc} [get_ports {eth_rxc}] -period {8} -waveform {0.000 4.000}
define_attribute {p:sys_clk} {PAP_IO_DIRECTION} {INPUT}
define_attribute {p:sys_clk} {PAP_IO_LOC} {B5}
define_attribute {p:sys_clk} {PAP_IO_VCCIO} {3.3}
define_attribute {p:sys_clk} {PAP_IO_STANDARD} {LVTTL33}
define_attribute {p:sys_clk} {PAP_IO_PULLUP} {TRUE}
define_attribute {p:sys_rst_n} {PAP_IO_DIRECTION} {INPUT}
define_attribute {p:sys_rst_n} {PAP_IO_LOC} {G5}
define_attribute {p:sys_rst_n} {PAP_IO_VCCIO} {1.5}
define_attribute {p:sys_rst_n} {PAP_IO_STANDARD} {LVCMOS15}
define_attribute {p:sys_rst_n} {PAP_IO_UNUSED} {TRUE}

